prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=${prefix}/@CMAKE_INSTALL_LIBDIR@
includedir=${prefix}/@CMAKE_INSTALL_INCLUDEDIR@

Name: libcoro
Description: C coroutine + event-loop base library
Version: @PROJECT_VERSION@
Requires: @LIBCORO_PC_REQUIRES@
Libs: -L${libdir} -lcoro
Libs.private: @LIBCORO_PC_LIBS_PRIVATE@
Cflags: -I${includedir}
